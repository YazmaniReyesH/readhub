# =============================================================================
# ReadHub — Variables de entorno
# =============================================================================
# Copia este archivo a `.env.local` y completa los valores con las credenciales
# de tu proyecto de Supabase (Project Settings → API / Database).
#
# `.env.local` NUNCA debe subirse al repositorio (ya está en .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — Claves públicas (expuestas al navegador)
# -----------------------------------------------------------------------------
# URL del proyecto:  Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Clave pública anónima:  Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# -----------------------------------------------------------------------------
# Supabase — Clave secreta (SOLO servidor, nunca exponer al navegador)
# -----------------------------------------------------------------------------
# Clave service_role:  Project Settings → API → Project API keys → service_role
# Se usa para scripts administrativos (seed) y validación de RLS.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# -----------------------------------------------------------------------------
# Base de datos — parámetros discretos (RECOMENDADO para los scripts db:*)
# -----------------------------------------------------------------------------
# Se prefieren parámetros separados porque el password se pasa literal, sin
# necesidad de percent-encoding aunque contenga $, @, :, etc.
#
# IMPORTANTE (redes IPv4): la "Direct connection" (db.<ref>.supabase.co) suele
# ser SOLO IPv6. Si tu red es IPv4, usa el "Session pooler":
#   Project Settings → Database → Connection string → pestaña "Session pooler".
#   Host:  aws-<n>-<region>.pooler.supabase.com
#   User:  postgres.<project-ref>
#   Port:  5432  (modo session; necesario para migraciones/DDL y SET LOCAL)
SUPABASE_DB_HOST=aws-1-us-west-2.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres.TU-PROYECTO
SUPABASE_DB_PASSWORD=tu-password-de-bd
SUPABASE_DB_NAME=postgres

# Alternativa: cadena de conexión completa (password percent-encoded) para
# psql o la CLI de Supabase. Los scripts db:* usan los parámetros de arriba si
# están presentes; si no, usan esta URI.
SUPABASE_DB_URL=postgresql://postgres.TU-PROYECTO:[PASSWORD-ENCODED]@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# Referencia del proyecto (el subdominio de la URL, p. ej. "abcd1234").
# Se usa con: npx supabase link --project-ref <ref>
SUPABASE_PROJECT_REF=tu-project-ref

# -----------------------------------------------------------------------------
# IA (Etapa 4 — RAG). SOLO servidor, nunca exponer al navegador.
# -----------------------------------------------------------------------------
# Voyage AI (embeddings): https://dash.voyageai.com
VOYAGE_API_KEY=tu-voyage-api-key
# Anthropic (chat/Claude): https://console.anthropic.com
ANTHROPIC_API_KEY=tu-anthropic-api-key
# Opcionales (valores por defecto en el código):
# ANTHROPIC_CHAT_MODEL=claude-opus-4-8
# VOYAGE_EMBEDDING_MODEL=voyage-3.5
