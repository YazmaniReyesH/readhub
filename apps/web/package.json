{
  "name": "@readhub/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:migrate": "node scripts/run-sql.mjs ../../supabase/migrations",
    "db:seed": "node scripts/run-sql.mjs ../../supabase/seed.sql",
    "db:test": "node scripts/run-sql.mjs ../../supabase/tests/rls_validation.sql",
    "db:setup": "npm run db:migrate && npm run db:seed && npm run db:test",
    "db:backfill": "tsx scripts/backfill-embeddings.ts",
    "gen:types": "supabase gen types typescript --linked > ../../packages/types/src/database.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@readhub/ai": "*",
    "@readhub/config": "*",
    "@readhub/database": "*",
    "@readhub/shared": "*",
    "@readhub/types": "*",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next": "15.5.20",
    "next-themes": "^0.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "pg": "^8.22.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
